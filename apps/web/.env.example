# Runtime URL used by Prisma Client / app requests.
# For Vercel + Supabase use the transaction pooler URL and keep the pool small.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadradar?connection_limit=1"

# Direct/session URL used by Prisma CLI for migrate deploy.
# In Supabase use the direct connection if available, otherwise the session pooler.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/leadradar"

PGBOSS_MAX_CONNECTIONS="1"
WORKER_PGBOSS_MAX_CONNECTIONS="1"
WORKER_CONCURRENCY="1"
PRISMA_LOG_QUERIES="false"
NEXTAUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
NEXTAUTH_URL="http://localhost:3000"

SERPAPI_API_KEY="your-serpapi-key"
RESEND_API_KEY="your-resend-key"
RESEND_WEBHOOK_SECRET="your-resend-webhook-secret"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_REPLY_TO="hera.contactanos@gmail.com"
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-chat"
AI_API_KEY="your-ai-api-key"
AI_TIMEOUT_MS="8000"

NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"
